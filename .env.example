# Copy to .env and uncomment the block that matches how you run tumbl.
# Docker Compose reads .env automatically for ${VAR} substitution.

# --- Shared settings ---
BLOG_TITLE=MyBlog
INDEX_WORKERS=4
# Optional default background (HTTPS URL or file path under archive/app root)
# BACKGROUND_IMAGE=https://example.com/background.jpg

# --- Local development (flask run) ---
ARCHIVE_PATH=.tumblrbackup
CACHE_DIR=.cache
FLASK_DEBUG=1
FLASK_RUN_PORT=8862

# --- Docker Compose overrides ---
# Uncomment these (and comment out the local block above) when using `docker compose up`.
# ARCHIVE_PATH=/archive
# CACHE_DIR=/app/cache

# TAG_EDITING_ENABLED=true

# --- Optional: WordPress WXR export (disabled by default) ---
# WORDPRESS_EXPORT_ENABLED=true
# WORDPRESS_EXPORT_AUTHOR=admin
# WORDPRESS_EXPORT_SITE_URL=https://usersite.com
# Post link template — placeholders: {site_url} {page} {id} {slug} {index}
# WORDPRESS_EXPORT_URL_TEMPLATE={site_url}/blog/?page={page}#post-{id}
# WORDPRESS_EXPORT_POSTS_PER_PAGE=20
# Public base URL for archive media — only needed if WordPress should download attachments:
# WORDPRESS_EXPORT_MEDIA_BASE_URL=https://cdn.example.com/tumblr-media
# WORDPRESS_EXPORT_MATCH_THEME=false
# WORDPRESS_EXPORT_MINIMAL=false
